Link to question: https://leetcode.com/problems/backspace-string-compare/description/



class Solution {
//string after backspaced
    public String afterBackspace(String a) {
        Stack<Character> st = new Stack<>();

        for(int i=0; i<a.length(); i++) {
            char ch = a.charAt(i);
            if(ch != '#') {
                st.push(ch);
            } else if(!st.isEmpty()) {
                st.pop();
            }
        }
        int n = st.size();
        char arr[] = new char[n];
        for(int i = n-1 ; i>=0; i--) {
            arr[i] = st.pop();
        }
        return new String(arr);
    }

    public boolean backspaceCompare(String s, String t) {
        s = afterBackspace(s);
        t = afterBackspace(t);

        return s.equals(t);
    }
}
