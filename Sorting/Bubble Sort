import java.util.*;
public class Main
{
	public static void main(String[] args) {
		int[] a = {7,3,5,2};
		int n = a.length;
		System.out.println(Arrays.toString(a));  //before sorting

		for(int i=0;i<n-1;i++) {
		    for(int j=0;j<n-i-1;j++) {
		        if(a[j]>a[j+1]){
		            int temp =a[j+1];
		            a[j+1] = a[j];
		            a[j] = temp;
		        }
		    }
		}
		System.out.println(Arrays.toString(a));  //after sorting
	} 
}

