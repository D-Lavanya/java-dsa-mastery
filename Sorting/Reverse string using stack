import java.util.*;
public class Main
{
	public static void main(String[] args) {
		String s = "Hello";
		Stack<Character> st = new Stack<>();
		
		for(int i=0;i<s.length();i++) {
		    st.push(s.charAt(i));
		}
		System.out.println(s); //before reverse
		
		String reversed ="";
		while(!st.isEmpty()){
		    reversed += st.pop();
		}
		
		System.out.println("Reversed array is: "+reversed); 
	}
}
