class Solution {
    public int findPeakElement(int[] nums) {

        int low = 0, high = nums.length - 1;

        while(low < high) {

            int mid = low + (high - low) / 2;

            if(nums[mid] > nums[mid + 1]) {
                high = mid;   // peak is on left side
            }
            else {
                low = mid + 1;  // peak is on right side
            }
        }

        return low;
    }
}
