class Solution {
    public int findPeakElement(int[] nums) {
        int  n = nums.length;

        if(n==1 || nums[0]>nums[1]) // if only 1 element present or checking the 0th index element
            return 0;

        for(int i =1;i<n-1;i++) {
            if(nums[i]>nums[i-1] && nums[i]>nums[i+1]) {
                return i;
            }
        }
        return n-1; //checking n-1 element as the for loop only checks upto n-2
    }
}


