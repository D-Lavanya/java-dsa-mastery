class Solution {
    public static long eatHours(int[] piles,int mid) {
        long res =0;
        for(int p:piles) {
            res+= (long)(p+mid-1)/mid;
        }
        return res;
    }
    public int minEatingSpeed(int[] piles, int h) {
        int low=1;
        int high = 0;

        for(int p:piles) {
            high = Math.max(high,p);
        }

        while(low<=high) {
            int mid = low+(high-low)/2;
            

            if(eatHours(piles,mid) <= h) {
                high =mid-1;
            }else {
                low = mid+1;
            }
        }
        return low;
    }
}
