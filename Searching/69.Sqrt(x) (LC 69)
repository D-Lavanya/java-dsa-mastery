class Solution {
    public int mySqrt(int x) {
        if(x==0 || x==1) {
            return x;
        }

        int l = 1, h = x;
        int res = 0;

        while(l<=h) {
            int mid = l + (h-l)/2;

            long sqr = (long)mid*mid;
            if(sqr <= x) {
                res = mid;  //inorder to reach x we need to move to right
                l = mid+1;
            } else {
                h = mid -1;   //inorder to reach x we need to move to left
            }
        }
        return res;
    }
}
