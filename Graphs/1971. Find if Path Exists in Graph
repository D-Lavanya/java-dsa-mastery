class Solution {
    public boolean validPath(int n, int[][] edges, int source, int destination) {
        List<List<Integer>> adj = new ArrayList<>();

        for(int i=0;i<n;i++) {
            adj.add(new ArrayList<>());
        }
        for(int[] ed:edges) {
            int u = ed[0];
            int v = ed[1];
            adj.get(u).add(v);
            adj.get(v).add(u);
        }

        Queue<Integer> q = new LinkedList<>();
        boolean vis[] = new boolean[n];

        q.add(source);
        vis[source] = true;

        while(!q.isEmpty()) {
            int curr = q.poll();
            if(vis[destination]) {
                return true;
            }
            for(int nei:adj.get(curr)) {
                if(!vis[nei]) {
                    q.add(nei);
                    vis[nei] = true;
                }
            }
        }
        return false;
    }
}
