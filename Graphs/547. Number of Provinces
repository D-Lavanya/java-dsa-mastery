class Solution {
    public int findCircleNum(int[][] g) {
        int n = g.length;
        boolean[] visited = new boolean[n];
        int count =0;

        for(int i=0;i<n;i++) {
            if(!visited[i]) {
                count++;
                dfs(i,g,visited,n);
            }
        }
        return count;
    }
    private void dfs(int i,int[][] g,boolean[] visited,int n) {
        visited[i] = true;
        for(int j=0;j<n;j++) {
            if(g[i][j]==1 && i!=j && !visited[j]) {
                dfs(j,g,visited,n);
            }
        }
    }
}
