//198.House robber recursion
//Leetcode
class Solution {
    public int rob(int[] nums) {
        return solve(nums,0);
    }
    static int solve(int[] nums,int i){
        if(i >= nums.length)    return 0;
        int rob = nums[i] + solve(nums, i+2);
        int skip = solve(nums, i+1);
        return Math.max(rob,skip);
    }
}
